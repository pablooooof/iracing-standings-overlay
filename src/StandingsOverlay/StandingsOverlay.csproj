<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>StandingsOverlay</RootNamespace>
    <AssemblyName>StandingsOverlay</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Version comes from git tags via MinVer (tag v0.4.0 → version 0.4.0). Never hand-edit. -->
    <MinVerTagPrefix>v</MinVerTagPrefix>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinForms is only used for the tray icon; keep its namespaces out of every file. -->
    <Using Remove="System.Drawing" />
    <Using Remove="System.Windows.Forms" />
    <InternalsVisibleTo Include="StandingsOverlay.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="irsdkSharp" Version="0.9.0" />
    <PackageReference Include="irsdkSharp.Serialization" Version="0.9.0" />
    <PackageReference Include="MinVer" Version="6.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <!-- Official corner numbers/names per track (Lap Lab turn view), keyed {trackId}_{config}. -->
    <Content Include="corners\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
