<Window x:Class="StandingsOverlay.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Standings Overlay — Settings"
        Width="780" Height="620" MinWidth="620" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="#16161C" Foreground="#E8E9EE"
        FontFamily="Segoe UI" FontSize="13" ShowInTaskbar="True">

    <Window.Resources>
        <!-- Palette matches the overlays: dark panel, cyan accent, dim secondary text. -->
        <SolidColorBrush x:Key="Accent"   Color="#00E6C3"/>
        <SolidColorBrush x:Key="Text"     Color="#E8E9EE"/>
        <SolidColorBrush x:Key="Dim"      Color="#9DA0AA"/>
        <SolidColorBrush x:Key="Line"     Color="#2C2C36"/>
        <SolidColorBrush x:Key="Control"  Color="#3A3A46"/>
        <SolidColorBrush x:Key="Panel"    Color="#1E1E26"/>

        <!-- Nav rail item: left accent bar + subtle fill when selected, no system blue. -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent">
                            <Grid>
                                <Border x:Name="Bar" Width="3" HorizontalAlignment="Left"
                                        Background="Transparent"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22222B"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#26262F"/>
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill toggle switch (a restyled CheckBox). -->
        <Style x:Key="Switch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="40" Height="22" CornerRadius="11"
                                Background="{StaticResource Control}">
                            <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="#C9C9CF"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#0C0C10"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Fill" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat horizontal slider: thin track, round thumb, click-to-page. -->
        <Style x:Key="FlatSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{StaticResource Control}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{StaticResource Accent}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="15" Height="15" Fill="#E8E9EE"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented picker button (grouped RadioButtons). -->
        <Style x:Key="Segment" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{StaticResource Control}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}" Margin="0,0,6,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A58"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="#0C0C10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark hex/text box. -->
        <Style x:Key="HexBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Control}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Footer link-style button. -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A33"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource LinkButton}">
            <Setter Property="Foreground" Value="#0C0C10"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="176"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: brand + nav rail. -->
        <Border Grid.Column="0" Background="#101014" BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,18,16,14">
                    <TextBlock Text="STANDINGS" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock Text="OVERLAY" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource Accent}"/>
                </StackPanel>
                <ListBox x:Name="Nav" DockPanel.Dock="Top" Background="Transparent"
                         BorderThickness="0" ItemContainerStyle="{StaticResource NavItem}"
                         SelectionChanged="OnNavChanged"/>
            </DockPanel>
        </Border>

        <!-- Right: section title, scrolling content, footer. -->
        <Grid Grid.Column="1" Background="#16161C">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="26,20,26,8">
                <TextBlock x:Name="SectionTitle" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource Text}"/>
                <TextBlock x:Name="SectionBlurb" Foreground="{StaticResource Dim}" FontSize="12.5"
                           TextWrapping="Wrap" Margin="0,3,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,4,20,10">
                <StackPanel x:Name="PageBody"/>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#101014" BorderBrush="{StaticResource Line}"
                    BorderThickness="0,1,0,0" Padding="20,10">
                <DockPanel>
                    <TextBlock x:Name="SavedHint" DockPanel.Dock="Left" Foreground="{StaticResource Dim}"
                               VerticalAlignment="Center" FontSize="12"
                               Text="Changes apply live and save automatically."/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset section" Style="{StaticResource LinkButton}"
                                Click="OnResetSection"/>
                        <Button Content="Close" Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0" Click="OnClose"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
