<Window x:Class="StandingsOverlay.UI.TrafficWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Traffic Alerter"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">

    <Window.Resources>
        <!-- Red border overlay that pulses while a row is imminent. -->
        <Style x:Key="PulseOverlay" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsImminent}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="RowPulse">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.25" To="1" Duration="0:0:0.35"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="RowPulse"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel x:Name="Root" Width="300">
        <TextBlock x:Name="EditHint" Text="TRAFFIC — drag to move" Visibility="Collapsed"
                   FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>

        <!-- ALONGSIDE banner: the sim spotter's CarLeftRight, shown only for alerted traffic. -->
        <Border x:Name="AlongsideBanner" Visibility="Collapsed" Height="36" CornerRadius="4"
                Background="#F03A1414" BorderBrush="#FF4040" BorderThickness="1.5">
            <TextBlock x:Name="AlongsideText" Text="◀   CAR LEFT" Foreground="#FFD7D7"
                       FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- CLEAR flash: 0.8 s confirmation that the traffic is through. -->
        <Border x:Name="ClearBanner" Visibility="Collapsed" Height="32" CornerRadius="4"
                Background="#F0212129" BorderBrush="#4CFF6A" BorderThickness="1">
            <TextBlock Text="✓   CLEAR" Foreground="#4CFF6A"
                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- STYLE A: stacked rows, nearest threat first. -->
        <ItemsControl x:Name="RowsControl" Visibility="Collapsed">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="36" Margin="0,0,0,4">
                        <Border Background="#F0212129" CornerRadius="4" BorderBrush="#34343F" BorderThickness="1"/>
                        <Border CornerRadius="4" BorderBrush="#FF4040" BorderThickness="1.5"
                                Style="{StaticResource PulseOverlay}"/>
                        <Grid Margin="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="2"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.RowSpan="2" Width="4" Background="{Binding StripeBrush}" CornerRadius="3,0,0,3"/>

                            <Border Grid.Column="1" Background="{Binding NumBrush}" CornerRadius="2"
                                    Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CarNumber}" Foreground="#17171D"
                                           FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5"
                                               Foreground="#E8E9EE" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding IRatingText}" Foreground="#9DA0AA"
                                               FontSize="10" Margin="5,2,0,0"/>
                                    <Border Background="{Binding BlueTagBrush}" CornerRadius="2" Padding="4,0"
                                            Margin="5,1,0,1" Visibility="{Binding BlueTagVisibility}">
                                        <TextBlock Text="BLUE" Foreground="White" FontSize="8.5" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#3A3A46" CornerRadius="2" Padding="4,0"
                                            Margin="5,1,0,1" Visibility="{Binding TrainVisibility}">
                                        <TextBlock Text="{Binding TrainText}" Foreground="#E8E9EE"
                                                   FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding SubText}" Foreground="#9DA0AA" FontSize="10"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,9,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TtaText}" Foreground="{Binding TtaBrush}"
                                               FontFamily="Consolas" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="s" Foreground="#9DA0AA" FontSize="10" Margin="1,4,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Chevrons}" Foreground="{Binding TtaBrush}"
                                               FontSize="9" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding RateText}" Foreground="#9DA0AA"
                                               FontFamily="Consolas" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding BarStar}"/>
                                    <ColumnDefinition Width="{Binding BarRestStar}"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding TtaBrush}"/>
                                <Border Grid.Column="1" Background="#18FFFFFF"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border x:Name="OverflowChip" Visibility="Collapsed" HorizontalAlignment="Center"
                Background="#C0212129" BorderBrush="#34343F" BorderThickness="1" CornerRadius="3" Padding="8,1">
            <TextBlock x:Name="OverflowText" Foreground="#9DA0AA" FontFamily="Consolas" FontSize="10"/>
        </Border>

        <!-- STYLE B: missile-lock beacon — giant TTA + chevron rain toward the YOU bar. -->
        <Border x:Name="BeaconPanel" Visibility="Collapsed" Width="150" HorizontalAlignment="Center"
                Background="#F0212129" CornerRadius="6" BorderBrush="#34343F" BorderThickness="1">
            <Grid>
                <Border x:Name="BeaconPulse" CornerRadius="6" BorderBrush="#FF4040" BorderThickness="1.5" Opacity="0"/>
                <StackPanel Margin="8,7">
                    <Border x:Name="BeaconClassBorder" CornerRadius="3" Padding="0,2,0,1">
                        <TextBlock x:Name="BeaconClassText" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="12" Foreground="#17171D"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock x:Name="BeaconTta" FontFamily="Consolas" FontWeight="Bold" FontSize="34"/>
                        <TextBlock x:Name="BeaconTtaUnit" Text="s" Foreground="#9DA0AA" FontSize="14" Margin="1,14,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="BeaconRate" HorizontalAlignment="Center"
                               FontFamily="Consolas" FontSize="11" Foreground="#9DA0AA"/>
                    <Canvas x:Name="ChevronCanvas" Height="40" ClipToBounds="True" Margin="0,3,0,0"/>
                    <Border x:Name="YouBar" Height="4" CornerRadius="2" Margin="10,2,10,0"/>
                    <TextBlock Text="Y O U" HorizontalAlignment="Center" FontSize="8.5"
                               Foreground="#9DA0AA" Margin="0,2,0,0"/>
                    <StackPanel x:Name="BeaconQueue" Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</Window>
