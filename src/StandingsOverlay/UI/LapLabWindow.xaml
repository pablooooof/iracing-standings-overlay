<Window x:Class="StandingsOverlay.UI.LapLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lap Lab"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">

    <StackPanel x:Name="Root">
        <TextBlock x:Name="EditHint" Text="LAP LAB — drag to move" Visibility="Collapsed"
                   FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>

        <Border x:Name="Panel" Background="#F0212129" CornerRadius="6"
                BorderBrush="#34343F" BorderThickness="1" Padding="10,6,10,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="LAP LAB" Foreground="#9DA0AA" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="RefText" FontFamily="Consolas" FontSize="11"
                               Foreground="#B8A2FF" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Lap table (header + rows), built in code-behind: sector count varies per track. -->
                <Grid x:Name="Table"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
