<Window x:Class="StandingsOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Standings Overlay"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">

    <!-- IsSharedSizeScope on the root so the column header and every row share column widths. -->
    <Border x:Name="RootBorder" CornerRadius="6" Padding="10,7" Grid.IsSharedSizeScope="True">
        <Border.Resources>
            <!-- Numeric cells: fixed-ish width, right aligned, so digits line up. -->
            <Style x:Key="Num" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,0,14,0"/>
            </Style>
            <Style x:Key="DeltaCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Width" Value="38"/>
            </Style>
        </Border.Resources>
        <StackPanel>
            <!-- Session header: RACE · SoF 2.4k · 12 laps -->
            <Grid Margin="2,0,2,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HeaderLeft" Grid.Column="0" FontWeight="Bold"/>
                <TextBlock x:Name="HeaderMid" Grid.Column="1" Margin="14,0" Opacity="0.75"/>
                <TextBlock x:Name="HeaderRight" Grid.Column="2" Opacity="0.75"/>
            </Grid>

            <!-- Column header -->
            <Grid x:Name="ColumnHeader" Margin="2,0,2,3" Opacity="0.55">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="cPos"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cNum"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cName" Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cIr"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cLic"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cGap"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cInt"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cLast" Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cDelta" Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPit"  Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="P"      Margin="0,0,10,0" MinWidth="18"/>
                <TextBlock Grid.Column="1" Text="#"      Margin="0,0,10,0" MinWidth="30"/>
                <TextBlock Grid.Column="2" Text="DRIVER" Margin="0,0,16,0" MinWidth="130"/>
                <TextBlock Grid.Column="3" Text="IR"     Style="{StaticResource Num}" MinWidth="34"/>
                <TextBlock Grid.Column="4" Text="LIC"    Margin="0,0,14,0" MinWidth="42"/>
                <TextBlock Grid.Column="5" Text="GAP"    Style="{StaticResource Num}" MinWidth="48"/>
                <TextBlock Grid.Column="6" Text="INT"    Style="{StaticResource Num}" MinWidth="44"/>
                <TextBlock Grid.Column="7" Text="LAST"   Style="{StaticResource Num}" MinWidth="58"/>
                <ItemsControl Grid.Column="8" x:Name="DeltaHeaderCells" Margin="0,0,4,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource DeltaCell}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Grid.Column="9" Text=""/>
            </Grid>

            <!-- Rows -->
            <ItemsControl x:Name="RowsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBackground}" CornerRadius="3" Padding="2,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="cPos"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cNum"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cName" Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cIr"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cLic"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cGap"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cInt"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cLast" Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cDelta" Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPit"  Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding PosText}" Margin="0,0,10,0" Opacity="0.9"/>
                                <TextBlock Grid.Column="1" Text="{Binding CarNumber}" Margin="0,0,10,0"
                                           Foreground="{Binding CarNumberBrush}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="{Binding Name}" Margin="0,0,16,0"
                                           Foreground="{Binding NameBrush}"/>
                                <TextBlock Grid.Column="3" Text="{Binding IRating}" Style="{StaticResource Num}" Opacity="0.85"/>
                                <TextBlock Grid.Column="4" Text="{Binding License}" Margin="0,0,14,0"
                                           Foreground="{Binding LicenseBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding Gap}" Style="{StaticResource Num}" Opacity="0.9"/>
                                <TextBlock Grid.Column="6" Text="{Binding Interval}" Style="{StaticResource Num}" Opacity="0.9"/>
                                <TextBlock Grid.Column="7" Text="{Binding LastLap}" Style="{StaticResource Num}" Opacity="0.9"/>
                                <ItemsControl Grid.Column="8" ItemsSource="{Binding DeltaCells}" Margin="0,0,4,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                                                       Style="{StaticResource DeltaCell}" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Grid.Column="9" Text="{Binding PitText}" Margin="8,0,0,0"
                                           Foreground="#FFB84D" FontSize="10" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Edit-mode hint -->
            <TextBlock x:Name="EditHint" Text="EDIT MODE — drag to move, use tray icon to finish"
                       Visibility="Collapsed" Margin="2,6,2,0" FontSize="11" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>
