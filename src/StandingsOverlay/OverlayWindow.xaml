<Window x:Class="StandingsOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Standings Overlay"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">

    <!-- IsSharedSizeScope on the root so the column header and every row share column widths.
         Window.DataContext is a ColumnVisibility instance (set from config) that all the
         per-column Visibility bindings below resolve against via AncestorType=Window. -->
    <Border x:Name="RootBorder" CornerRadius="6" Padding="10,7" Grid.IsSharedSizeScope="True">
        <Border.Resources>
            <Style x:Key="Num" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,0,14,0"/>
            </Style>
            <Style x:Key="DeltaCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Right"/>
            </Style>
        </Border.Resources>
        <StackPanel>
            <!-- Session header: grouped metric pills — [RACE] [time · laps · clock] [SoF · temp · x]
                 [wetness · rain% · wind]. Each cluster is its own faintly-tinted rounded box. -->
            <StackPanel x:Name="HeaderBar" Orientation="Horizontal" Margin="2,0,2,6" TextElement.FontSize="13">
                <Border x:Name="HeaderLeftPill" CornerRadius="5" Padding="8,2" Margin="0,0,6,0"
                        Background="#33FFFFFF" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderLeft" FontWeight="Bold"/>
                </Border>
                <!-- Alert flash: blinks for a few seconds on dry→wet or a dry↔wet tyre switch. -->
                <Border x:Name="WeatherFlash" CornerRadius="5" Padding="8,2" Margin="0,0,6,0"
                        Background="#FF3B30" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="WeatherFlashText" FontWeight="Bold" Foreground="White"/>
                </Border>
                <ItemsControl x:Name="HeaderGroups" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="5" Padding="8,2" Margin="0,0,6,0"
                                    Background="#1EFFFFFF" VerticalAlignment="Center">
                                <TextBlock Text="{Binding}" Opacity="0.92"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Marshal declared wet (wet tyres allowed) — a separate flag from the surface wetness. -->
                <Border x:Name="WetPill" CornerRadius="5" Padding="7,2" Margin="0,0,6,0"
                        Background="#1E6FFF" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="WET" FontWeight="Bold" Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- Column header -->
            <Grid x:Name="ColumnHeader" Margin="2,0,2,3" Opacity="0.55">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="cPos"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cBar"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cTyre"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPg"    Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cNum"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cName"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cIr"    Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cCar"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cLic"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cLaps"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cGap"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cInt"   Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cBest"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cLast"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cDelta" Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cRank"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cStrat" Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPace"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cStat"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPitL"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPitT"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPitD"  Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="cPitS"  Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="P"      Margin="0,0,8,0" MinWidth="18"/>
                <TextBlock Grid.Column="1"  Text=""       Margin="0,0,7,0"/>
                <TextBlock Grid.Column="2"  Text=""       Margin="0,0,8,0" MinWidth="13"
                           Visibility="{Binding Tyre}"/>
                <TextBlock Grid.Column="3"  Text="±"      Style="{StaticResource Num}" MinWidth="24"
                           Visibility="{Binding PosGained}"/>
                <TextBlock Grid.Column="4"  Text="#"      Margin="0,0,10,0" MinWidth="30"/>
                <TextBlock Grid.Column="5"  Text="DRIVER" Margin="0,0,16,0"
                           Width="{Binding NameWidth}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="6"  Text="IR"     Style="{StaticResource Num}" MinWidth="34"
                           Visibility="{Binding IRating}"/>
                <TextBlock Grid.Column="7"  Text="CAR"    Margin="0,0,14,0" MinWidth="30"
                           Visibility="{Binding CarBrand}"/>
                <TextBlock Grid.Column="8"  Text="LIC"    Margin="0,0,14,0" MinWidth="42"
                           Visibility="{Binding License}"/>
                <TextBlock Grid.Column="9"  Text="LAPS"   Style="{StaticResource Num}" MinWidth="36"
                           Visibility="{Binding LapsCount}"/>
                <TextBlock Grid.Column="10" Text="GAP"    Style="{StaticResource Num}" MinWidth="48"
                           Visibility="{Binding Gap}"/>
                <TextBlock Grid.Column="11" Text="INT"    Style="{StaticResource Num}" MinWidth="44"
                           Visibility="{Binding Interval}"/>
                <TextBlock Grid.Column="12" Text="BEST"   Style="{StaticResource Num}" MinWidth="58"
                           Visibility="{Binding BestLap}"/>
                <TextBlock Grid.Column="13" Text="LAST"   Style="{StaticResource Num}" MinWidth="58"
                           Visibility="{Binding LastLap}"/>
                <ItemsControl Grid.Column="14" x:Name="DeltaHeaderCells" Margin="0,0,10,0"
                              Visibility="{Binding Delta}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource DeltaCell}"
                                       Width="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Grid.Column="15" Text="FST"   Style="{StaticResource Num}" MinWidth="30"
                           Visibility="{Binding PaceRank}"/>
                <TextBlock Grid.Column="16" Text="PIT"   Style="{StaticResource Num}" MinWidth="40"
                           Visibility="{Binding Strategy}"/>
                <TextBlock Grid.Column="17" Text="PACE"  Margin="0,0,10,0" MinWidth="34"
                           Visibility="{Binding Pace}"/>
                <TextBlock Grid.Column="18" Text=""      MinWidth="30"
                           Visibility="{Binding Status}"/>
                <TextBlock Grid.Column="19" Text="P·LAP" Style="{StaticResource Num}" MinWidth="34"
                           Visibility="{Binding PitLap}"/>
                <TextBlock Grid.Column="20" Text="P·TOT" Style="{StaticResource Num}" MinWidth="40"
                           Visibility="{Binding PitTotal}"/>
                <TextBlock Grid.Column="21" Text="P·DRV" Style="{StaticResource Num}" MinWidth="40"
                           Visibility="{Binding PitDrive}"/>
                <TextBlock Grid.Column="22" Text="P·BOX" Style="{StaticResource Num}" MinWidth="40"
                           Visibility="{Binding PitStall}"/>
            </Grid>

            <!-- Rows -->
            <ItemsControl x:Name="RowsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBackground}" CornerRadius="3" Padding="2,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="cPos"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cBar"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cTyre"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPg"    Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cNum"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cName"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cIr"    Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cCar"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cLic"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cLaps"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cGap"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cInt"   Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cBest"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cLast"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cDelta" Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cRank"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cStrat" Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPace"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cStat"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPitL"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPitT"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPitD"  Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="cPitS"  Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding PosText}" Margin="0,0,8,0" Opacity="0.9"/>
                                <!-- Class color bar (the iOverlay-style separator) -->
                                <Rectangle Grid.Column="1" Width="3" Margin="0,1,7,1" RadiusX="1" RadiusY="1"
                                           Fill="{Binding ClassBarBrush}"/>
                                <!-- Tyre compound ring: gray = dry, blue = wet. On a dry↔wet switch,
                                     briefly show old→new rings instead. -->
                                <Grid Grid.Column="2" Margin="0,0,8,0"
                                      Visibility="{Binding DataContext.Tyre, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Ellipse Width="13" Height="13" StrokeThickness="3.5" VerticalAlignment="Center"
                                             Stroke="{Binding TyreBrush}" Fill="#1A1A1E"
                                             Visibility="{Binding TyreVisibility}"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                Visibility="{Binding TyreSwitchVisibility}">
                                        <Ellipse Width="10" Height="10" StrokeThickness="2.5" Stroke="{Binding TyreOldBrush}" Fill="#1A1A1E"/>
                                        <TextBlock Text="→" FontSize="9" Foreground="#C9C9CF" Margin="1,0" VerticalAlignment="Center"/>
                                        <Ellipse Width="10" Height="10" StrokeThickness="2.5" Stroke="{Binding TyreBrush}" Fill="#1A1A1E"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Column="3" Text="{Binding PosGained}" Style="{StaticResource Num}"
                                           Foreground="{Binding PosGainedBrush}" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.PosGained, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="4" Text="{Binding CarNumber}" Margin="0,0,10,0"
                                           Foreground="{Binding CarNumberBrush}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="5" Text="{Binding Name}" Margin="0,0,16,0"
                                           Foreground="{Binding NameBrush}" FontWeight="{Binding NameWeight}"
                                           TextTrimming="CharacterEllipsis"
                                           Width="{Binding DataContext.NameWidth, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <!-- iRating chip (iOverlay style: light pill, dark text) -->
                                <Grid Grid.Column="6"
                                      Visibility="{Binding DataContext.IRating, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Border Background="#E9E9EC" CornerRadius="4" Padding="5,0" Margin="0,1,14,1"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Visibility="{Binding IrChipVisibility}">
                                        <TextBlock Text="{Binding IRating}" Foreground="Black"
                                                   FontSize="10.5" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                <!-- Car brand -->
                                <TextBlock Grid.Column="7" Text="{Binding CarBrand}" Margin="0,0,14,0"
                                           Opacity="0.75" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.CarBrand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <!-- License chip: license color as background, contrasting text -->
                                <Grid Grid.Column="8"
                                      Visibility="{Binding DataContext.License, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Border Background="{Binding LicenseBrush}" CornerRadius="4" Padding="5,0" Margin="0,1,14,1"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Visibility="{Binding LicChipVisibility}">
                                        <TextBlock Text="{Binding License}" Foreground="{Binding LicenseTextBrush}"
                                                   FontSize="10.5" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                                <TextBlock Grid.Column="9" Text="{Binding Laps}" Style="{StaticResource Num}" Opacity="0.85"
                                           Visibility="{Binding DataContext.LapsCount, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="10" Text="{Binding Gap}" Style="{StaticResource Num}" Opacity="0.9"
                                           Visibility="{Binding DataContext.Gap, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="11" Text="{Binding Interval}" Style="{StaticResource Num}" Opacity="0.9"
                                           Visibility="{Binding DataContext.Interval, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="12" Text="{Binding BestLap}" Style="{StaticResource Num}"
                                           Foreground="{Binding BestLapBrush}" Opacity="0.95"
                                           Visibility="{Binding DataContext.BestLap, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="13" Text="{Binding LastLap}" Style="{StaticResource Num}" Opacity="0.9"
                                           Visibility="{Binding DataContext.LastLap, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <ItemsControl Grid.Column="14" ItemsSource="{Binding DeltaCells}" Margin="0,0,10,0"
                                              Visibility="{Binding DataContext.Delta, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                                                       Style="{StaticResource DeltaCell}" FontWeight="SemiBold"
                                                       Width="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Fastest-on-track rank (last 5 clean laps, per class) -->
                                <TextBlock Grid.Column="15" Text="{Binding Rank}" Style="{StaticResource Num}"
                                           Foreground="{Binding RankBrush}" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.PaceRank, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="16" Text="{Binding Strat}" Style="{StaticResource Num}"
                                           Opacity="0.9" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.Strategy, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="17" Text="{Binding Pace}" Margin="0,0,10,0"
                                           Foreground="{Binding PaceBrush}" FontWeight="SemiBold"
                                           Visibility="{Binding DataContext.Pace, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <!-- Status: penalties are rounded-square flags; PIT/SPUN stay text badges -->
                                <StackPanel Grid.Column="18" Orientation="Horizontal"
                                            Visibility="{Binding DataContext.Status, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Grid VerticalAlignment="Center" Visibility="{Binding FlagVisibility}">
                                        <Rectangle Width="18" Height="15" RadiusX="3.5" RadiusY="3.5" StrokeThickness="1.8"
                                                   Fill="{Binding FlagBodyBrush}" Stroke="{Binding FlagStrokeBrush}"/>
                                        <Ellipse Width="7" Height="7" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Fill="{Binding FlagDotBrush}" Visibility="{Binding FlagDotVisibility}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBrush}"
                                               FontSize="11" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Grid.Column="19" Text="{Binding PitLap}" Style="{StaticResource Num}"
                                           Opacity="0.85" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.PitLap, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="20" Text="{Binding PitTotal}" Style="{StaticResource Num}"
                                           Opacity="0.9" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.PitTotal, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="21" Text="{Binding PitDrive}" Style="{StaticResource Num}"
                                           Opacity="0.75" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.PitDrive, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Grid.Column="22" Text="{Binding PitStall}" Style="{StaticResource Num}"
                                           Opacity="0.9" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding DataContext.PitStall, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Edit-mode hint -->
            <TextBlock x:Name="EditHint" Text="EDIT MODE — drag to move, use tray icon to finish"
                       Visibility="Collapsed" Margin="2,6,2,0" FontSize="11" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>
